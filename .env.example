# Copy this file to .env and fill in your values.

# ── Django core ──────────────────────────────────────────────────────────────
# Generate a new key with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string

# Set to 0 / false / no in production
DJANGO_DEBUG=True

# Comma-separated list of allowed hostnames in production, e.g. mysite.com,www.mysite.com
# Leave blank to default to ['*'] in debug or [] in production
DJANGO_ALLOWED_HOSTS=

# ── Test / seed accounts (debug only) ────────────────────────────────────────
TEST_ADMIN_EMAIL=admin@example.com
TEST_ADMIN_PASSWORD=admin123

# ── Recovery admin ────────────────────────────────────────────────────────────
# This account is auto-created on startup for emergency access.
# Set RECOVERY_ADMIN_ENABLED=0 to disable it in production.
RECOVERY_ADMIN_ENABLED=1
RECOVERY_ADMIN_EMAIL=iceberg.edu.center@gmail.com
RECOVERY_ADMIN_PASSWORD=iceberg

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# Leave blank to use the file-based backend in debug mode.
# In production set these to your Gmail / SMTP provider credentials.
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# ── Firebase Cloud Messaging ──────────────────────────────────────────────────
# Server key from the Firebase Console → Project Settings → Cloud Messaging
FCM_SERVER_KEY=
